{
    "name": "al-tool",
    "private": true,
    "version": "0.0.0",
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "client:dev": "npm --workspace=apps/client run dev",
        "client:build": "npm --workspace=apps/client run build",
        "desktop:dev": "npm --workspace=apps/desktop run dev",
        "desktop:build": "npm --workspace=apps/desktop run build",
        "backend:dev": "cd backend && . .venv/bin/activate && python -m altool.main",
        "backend:test": "cd backend && . .venv/bin/activate && pytest",
        "sidecar:build": "bash packaging/build-sidecar.sh",
        "app:dist": "npm run client:build && npm run sidecar:build && npm run desktop:build && npm --workspace=apps/desktop run dist",
        "install:all": "npm install"
    }
}
